# ─── Amazon DocumentDB Connection ─────────────────────────────────────────────
# Format:
# mongodb://username:password@your-cluster.cluster-xxxx.region.docdb.amazonaws.com:27017/dbname?tls=true&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false
MONGODB_URI=mongodb://username:password@your-cluster.cluster-xxxx.eu-north-1.docdb.amazonaws.com:27017/verde-nyc?tls=true&replicaSet=rs0&readPreference=secondaryPreferred&retryWrites=false

# Set to 'true' when using DocumentDB with TLS enabled
DOCDB_TLS=true

# S3 Configuration (use S3_ prefix — AWS_ is reserved by Amplify)
S3_REGION=eu-north-1
S3_ACCESS_KEY_ID=your_aws_access_key_here
S3_SECRET_ACCESS_KEY=your_aws_secret_key_here
S3_BUCKET_NAME=verde-nyc-s3

# Backend API URL (for CMS to connect to backend)
NEXT_PUBLIC_API_URL=http://localhost:4000/api

# JWT Secret — must EXACTLY match the backend JWT_SECRET!
JWT_SECRET=verde-cms-super-secret-2024-change-this

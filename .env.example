# MongoDB Connection (same as backend)
MONGODB_URI=mongodb://localhost:27017/verde-nyc
# Or MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/database

# AWS S3 Configuration (same as backend)
AWS_REGION=eu-north-1
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_S3_BUCKET_NAME=verde-nyc-s3

# Backend API URL (for CMS to connect to backend)
NEXT_PUBLIC_API_URL=http://localhost:4000/api
